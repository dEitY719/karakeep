karakeep:
  url: http://localhost:3001
  api_key: ${KARAKEEP_API_KEY}

# ObsidianVault-PARA 의 최상위 경로. bootstrap.sh 가 이 PC 경로로 자동 치환한다.
vault_root: /mnt/c/Users/CHANGE_ME/Documents/ObsidianVault-PARA

# 사내(80-Company) 전용으로 취급할 Karakeep top-level 리스트 (§4.3 능동 차단 가드레일).
# 이 리스트의 북마크는 is_company repo(아래 company)로만 export 되고, 공용 GitHub repo 로는
# 절대 나가지 않는다 — exclude_lists 설정 누락 시에도 유출을 막는 다층 방어다.
# 생략 시 company repo 의 include_lists 에서 자동 유도된다(external/home 에서도 인지).
company_lists: [Company]

repos:
  # 공용 북마크 (GitHub) — 전 PC 공유. internal 모드에선 pull-only (push 금지).
  common:
    path: 30-Resource/Bookmarks
    remote: https://${GITHUB_PAT}@github.com/dEitY719/bookmarks-common.git
    pull: true
    # 이 top-level 리스트에 속한 북마크는 공개 GitHub repo export 에서 제외한다.
    # 단일 공유 Karakeep 인스턴스(예: Tailscale Funnel)에서 사내 북마크가 공개
    # repo 로 새어나가지 않게 하는 안전장치. 회사 북마크는 Karakeep 의 'Company'
    # 리스트에 넣으면 된다 (웹에선 보이되 markdown export 는 안 됨).
    exclude_lists: [Company]
  # 사내 북마크 (GHES) — internal 모드에서만 활성 (config.py 가 그 외 모드에선 skip).
  company:
    path: 80-Company/Bookmarks
    # SSOT(#38): owner 도 ${GHES_OWNER} 로 — vault-sync.sh §8 이 조립하는 URL 과 '동일
    # 컴포넌트'(GHES_PAT/GHES_HOST/GHES_OWNER)에서 나오게 한다. 여기에 리터럴 owner 를
    # 박으면 GHES_OWNER≠그 리터럴일 때 karakeep-sync 와 vault-sync.sh 가 매 실행
    # git remote set-url 로 번갈아 덮어써 remote churn/간헐 실패가 생긴다.
    remote: https://${GHES_PAT}@${GHES_HOST}/${GHES_OWNER}/bookmarks-company.git
    pull: true
    # 사내 전용 repo 표식 — company_lists 북마크의 유일한 합법 목적지(§4.3).
    # repo 이름이 'company' 면 자동 True 이지만 명시해 둔다.
    is_company: true
    # 'Company' 리스트 북마크만 GHES 로 export (전체 북마크가 사내 깃에 쌓이는 것 방지).
    # exclude_lists 의 반대 — 화이트리스트. 회사 북마크는 Karakeep 'Company' 리스트에 넣는다.
    include_lists: [Company]

logs:
  dir: ~/apps/karakeep/logs
  retention_days: 30
