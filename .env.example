# [1단계] 컨테이너 기동 전 입력 — Karakeep 서버가 읽는 값
#         (없으면 회원가입/로그인 시 internal server error 발생)
NEXTAUTH_SECRET=                      # openssl rand -base64 36 으로 생성
NEXTAUTH_URL=http://localhost:3001    # 실제 접속 포트에 맞게
DATA_DIR=/data                        # DB 저장 경로 (없으면 컨테이너 내부에 임시 생성 → 재시작 시 초기화)

# [2단계] 컨테이너 기동 후 입력 — karakeep-sync 만 읽음 (컨테이너는 안 읽음)
#         API key 는 docker compose up 후 http://localhost:3001 접속해서 발급
KARAKEEP_API_KEY=ak2_xxxxxxxxxxxxxxxxxxxx                     # Karakeep UI → Settings → API Keys 에서 발급
KARAKEEP_URL=http://localhost:3001   # internal/home: 공유 인스턴스 URL 로 변경 (예: Tailscale Funnel). external: localhost.
GIT_TRANSPORT=auto                   # auto|ssh|https — auto: bootstrap 이 SSH 인증되면 ssh 로 고정(PAT 불필요), 안 되면 https
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx  # GIT_TRANSPORT=https 일 때만 필요 (ssh 면 생략 가능). GitHub → Settings → Developer settings → Tokens
GHES_PAT=ghes_xxxxxxxxxxxxxxxxxxxx   # 회사 PC만 · GIT_TRANSPORT=https 일 때만 필요 (ssh 면 생략 가능)
GHES_HOST=ghes.your-company.internal # 회사 PC만 (ssh 여도 remote 조립에 필요)
GHES_OWNER=dEitY719                  # 회사 PC만 — GHES 계정/조직 (bookmarks-company owner, ssh 여도 필요)
